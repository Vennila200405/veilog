module part_select_tb;
reg [7:0]byte;
wire msb;
bit_select d(byte, msb);
initial begin
	$monitor("@time=%0t | in=%b | sign=%b //sign is 0 for +ve numbers and 1 for -ve numbers",$time,byte, msb);
	byte=8'b00001111;
	#10 byte=8'b11010000;
	#10 byte=8'b01110001;
	#10 byte=8'b11111111;
	#10 $finish;
end
endmodule
